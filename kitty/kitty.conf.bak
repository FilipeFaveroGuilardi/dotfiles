background_opacity 0.97
font-family "CommitMono Nerd Font:style=Regular"
include ~/.local/share/tinted-theming/tinty/tinted-terminal-themes-kitty-file.conf


# BEGIN_KITTY_FONTS
font_family      family='CommitMono Nerd Font Mono' postscript_name=CommitMonoNFM-Regular
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS